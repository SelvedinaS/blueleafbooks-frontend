# MongoDB Connection
MONGODB_URI=mongodb://127.0.0.1:27017/blueleafbooks

# JWT Secret
JWT_SECRET=your-jwt-secret-key

# Server Port
PORT=3000

# PayPal Configuration (Sandbox)
# For direct-to-author: Create app with type "Platform" (marketplace), not "Merchant"
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox
# true = money goes directly to author. false = platform receives, you pay authors manually.
PAYPAL_SEND_TO_AUTHORS=true

# Platform Fee Percentage
PLATFORM_FEE_PERCENTAGE=5

# Admin Account (example values)
ADMIN_EMAIL=blueleafbooks@hotmail.com
ADMIN_PASSWORD=change-me

# Password reset support
# Password resets are handled manually by BlueLeafBooks support.
FRONTEND_BASE_URL=https://your-frontend.netlify.app

# Backend public URL (for full image/PDF URLs in API responses). Render sets RENDER_EXTERNAL_URL automatically.
# BACKEND_URL=https://your-backend.onrender.com

# DigitalOcean Spaces (for cover images and PDF files)
# Use either SPACES_* or DO_SPACES_* (both work)
SPACES_BUCKET=your-space-name
SPACES_REGION=nyc3
SPACES_KEY=your-spaces-access-key
SPACES_SECRET=your-spaces-secret-key
# Or: DO_SPACES_BUCKET, DO_SPACES_REGION (e.g. fra1), DO_SPACES_KEY, DO_SPACES_SECRET
# Optional: DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
